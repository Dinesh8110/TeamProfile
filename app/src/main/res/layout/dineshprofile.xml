<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/teambg2"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:layout_margin="8dp">


        <!-- Profile Picture -->
        <ImageView
            android:id="@+id/profilePicture"
            android:layout_width="140dp"
            android:layout_height="160dp"
            android:src="@drawable/dinesh"
            android:layout_marginBottom="16dp"
            android:scaleType="centerCrop"
            android:contentDescription="Profile Picture" />

        <!-- Name -->
        <TextView
            android:id="@+id/profileName1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dinesh Sankar"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <!-- Role -->
        <TextView
            android:id="@+id/profileRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-black"
            android:text="Software Engineer | Android Developer"
            android:textAppearance="@style/TextAppearance.AppCompat.Large"
            android:textColor="#B0BEC5"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Contact Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/contactEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:drawablePadding="8dp"
                android:text="sdinesh@student.com"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/contactPhone1"
                android:layout_width="124dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"

                android:drawablePadding="8dp"
                android:text="8220483837"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Skills Section -->
        <TextView
            android:id="@+id/skillsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="sans-serif"
            android:text="Technical Skills"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="177dp"
            android:layout_marginBottom="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/skill1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="• Java"
                android:textColor="#B0BEC5"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/skill2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="• Python"
                android:textColor="#B0BEC5"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/skill3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="• FullStack Development"
                android:textColor="#B0BEC5"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/skill4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="• Firebase"
                android:textColor="#B0BEC5"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/skill5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="• UI/UX Design"
                android:textColor="#B0BEC5"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Button -->
        <Button
            android:id="@+id/contactButton1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#4CAF50"
            android:padding="10dp"
            android:text="Contact Me"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginTop="10dp" />
    </LinearLayout>
</ScrollView>
